package com.abualqasim.transferpro

import android.Manifest
import android.content.Intent
import android.content.pm.PackageManager
import android.net.Uri
import android.os.Bundle
import android.widget.Toast
import androidx.activity.result.contract.ActivityResultContracts
import androidx.appcompat.app.AppCompatActivity
import androidx.core.content.ContextCompat
import androidx.lifecycle.lifecycleScope
import com.abualqasim.transferpro.databinding.ActivityMainBinding
import kotlinx.coroutines.launch
import java.io.File

class MainActivity : AppCompatActivity() {

    private lateinit var binding: ActivityMainBinding
    private lateinit var transferManager: FileTransferManager
    private var selectedUri: Uri? = null
    private val PORT = 8888

    private val permissionLauncher = registerForActivityResult(
        ActivityResultContracts.RequestMultiplePermissions()
    ) { permissions ->
        val allGranted = permissions.values.all { it }
        if (!allGranted) {
            Toast.makeText(this, "يلزم منح جميع الأذونات لتشغيل التطبيق", Toast.LENGTH_LONG).show()
        }
    }

    override fun onCreate(savedInstanceState: Bundle?) {
        super.onCreate(savedInstanceState)
        binding = ActivityMainBinding.inflate(layoutInflater)
        setContentView(binding.root)

        transferManager = FileTransferManager(this)
        requestNeededPermissions()

        binding.btnSend.setOnClickListener { openFilePicker() }
        binding.btnReceive.setOnClickListener { startReceiving() }
        binding.btnAbout.setOnClickListener { showAboutFragment() }
    }

    private fun requestNeededPermissions() {
        val permissions = listOf(
            Manifest.permission.READ_EXTERNAL_STORAGE,
            Manifest.permission.READ_CONTACTS,
            Manifest.permission.WRITE_EXTERNAL_STORAGE
        ).filter {
            ContextCompat.checkSelfPermission(this, it) != PackageManager.PERMISSION_GRANTED
        }.toTypedArray()

        if (permissions.isNotEmpty()) {
            permissionLauncher.launch(permissions)
        }
    }

    private fun openFilePicker() {
        val intent = Intent(Intent.ACTION_OPEN_DOCUMENT)
        intent.addCategory(Intent.CATEGORY_OPENABLE)
        intent.type = "*/*"
        startActivityForResult(intent, 100)
    }

    override fun onActivityResult(requestCode: Int, resultCode: Int, data: Intent?) {
        super.onActivityResult(requestCode, resultCode, data)
        if (requestCode == 100 && resultCode == RESULT_OK) {
            selectedUri = data?.data
            val ip = binding.editIp.text.toString().trim()
            if (ip.isNotEmpty() && selectedUri != null) {
                startSending(ip, selectedUri!!)
            } else {
                Toast.makeText(this, "يرجى إدخال IP صحيح واختيار ملف", Toast.LENGTH_SHORT).show()
            }
        }
    }

    private fun startSending(ip: String, uri: Uri) {
        lifecycleScope.launch {
            try {
                binding.tvStatus.text = getString(R.string.status_sending)
                transferManager.sendFile(ip, PORT, uri, 0) { progress, totalRead ->
                    runOnUiThread {
                        binding.progressBar.progress = (progress * 100).toInt()
                        binding.tvStatus.text = "إرسال: ${(progress * 100).toInt()}%"
                    }
                }
                runOnUiThread {
                    binding.tvStatus.text = getString(R.string.status_done)
                    binding.progressBar.progress = 100
                }
            } catch (e: Exception) {
                runOnUiThread {
                    binding.tvStatus.text = getString(R.string.status_error, e.message)
                }
            }
        }
    }

    private fun startReceiving() {
        val dir = File(getExternalFilesDir(null), "ReceivedFiles")
        if (!dir.exists()) dir.mkdirs()

        lifecycleScope.launch {
            try {
                binding.tvStatus.text = getString(R.string.status_receiving)
                transferManager.receiveFile(PORT, dir) { progress, fileName, done ->
                    runOnUiThread {
                        binding.progressBar.progress = (progress * 100).toInt()
                        binding.tvStatus.text = if (done) {
                            "اكتمل: $fileName"
                        } else {
                            "استلام: $fileName ${(progress * 100).toInt()}%"
                        }
                    }
                }
                runOnUiThread {
                    binding.tvStatus.text = getString(R.string.status_done)
                }
            } catch (e: Exception) {
                runOnUiThread {
                    binding.tvStatus.text = getString(R.string.status_error, e.message)
                }
            }
        }
    }

    private fun showAboutFragment() {
        val fragment = AboutFragment()
        supportFragmentManager.beginTransaction()
            .replace(android.R.id.content, fragment)
            .addToBackStack(null)
            .commit()
    }
}
